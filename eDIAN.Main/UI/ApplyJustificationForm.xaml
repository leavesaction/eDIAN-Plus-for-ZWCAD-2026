<UserControl x:Class="eDIAN.Main.UI.ApplyJustificationForm"             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:eDIAN.Main.UI"
             mc:Ignorable="d" d:DesignWidth="360">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Width="360"  Height="34" CornerRadius="6,6,0,0" Padding="10,0,6,0" Background="#FF29313C" BorderThickness="1" BorderBrush="#FF4D5D78" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <TextBlock x:Name="TitleTextBlock" VerticalAlignment="Center" Foreground="#FFF5F5F5" FontSize="13" FontWeight="Bold">정당성 사유 입력</TextBlock>
        </Border>

        <Border Grid.Row="1" Width="360" Height="38" Padding="10,0,0,0" Background="#FF3B4453" BorderThickness="1,0,1,0" BorderBrush="#FF4D5D78">
            <TextBlock x:Name="JustificationMessageTextBlock" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#FFF5F5F5">
                정당성 사유를 입력하세요. (최대 500자)
            </TextBlock>
        </Border>

        <Border Grid.Row="2" Width="360" Padding="10,0,10,10" Background="#FF3B4453" BorderThickness="1,0,1,0" BorderBrush="#FF4D5D78">
            <Border CornerRadius="4" Padding="2" Background="#FF1F262E" BorderThickness="1" BorderBrush="#FF7C838D">
                <TextBox x:Name="JustificationTextBox" Padding="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontSize="12" BorderThickness="0" Foreground="#FFF5F5F5" Background="#FF1F262E"/>
            </Border>    
        </Border>

        <Border Grid.Row="3" Width="360" CornerRadius="0,0,6,6" Padding="10,0,10,6" Background="#FF3B4453" BorderThickness="1,0,1,1" BorderBrush="#FF4D5D78">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0"/>
                <Grid Grid.Column="1">
                    <StackPanel Orientation="Horizontal">

                        <Button x:Name="ButtonApply" Background="Transparent" Width="50" Height="24" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickApplyJustification">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Image x:Name="ImageApply" Source="/eDIAN;component/Resources/images/image_popup_apply_on.png" Width="50" Height="24" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ImageApply" Property="Source" Value="/eDIAN;component/Resources/images/image_popup_apply_over.png" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Width="5"/>
                        <Button x:Name="ButtonCancel" Background="Transparent" Width="50" Height="24" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickCloseForm">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Image x:Name="ImageCancel" Source="/eDIAN;component/Resources/images/image_popup_cancel_on.png" Width="50" Height="24" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ImageCancel" Property="Source" Value="/eDIAN;component/Resources/images/image_popup_cancel_over.png" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</UserControl>