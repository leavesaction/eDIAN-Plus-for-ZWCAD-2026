<UserControl x:Class="eDIAN.Main.UI.MainForm" 
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:eDIAN.Main.UI"
             Background="#FF313841"
             mc:Ignorable="d"
             FontFamily="맑은 고딕"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />

            <!-- 기본 템플릿 대신 정의한 템플릿 사용 -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 여기 Border가 실제로 그려지는 영역 -->
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 호버/프레스 등에서 배경을 건드리지 않음 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Width="6"><!--좌측 여백--></Grid>
        <Grid Grid.Column="1">

            <Grid Margin="0" Background="#FF313841">

                <Grid.RowDefinitions>
                    <RowDefinition Height="74" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF424C58" CornerRadius="0,0,6,6" Padding="6,6,6,6">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <!-- [로고 이미지, 환경 설정, 로그인/아웃 버튼 영역] -->

                        <Grid Grid.Row="0" Height="34">

                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Height="34"  HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <!-- 로고 이미지 -->
                                    <Image x:Name="IconLogo" Source="/eDIAN;component/Resources/images/icon_logo_1.png" Width="65" Height="25" Margin="0,2,0,0" VerticalAlignment="Top" />
                                </Grid>

                                <StackPanel Grid.Column="1" Height="34" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <!-- 설정 버튼 -->
                                    <Button x:Name="ButtonSetting" Margin="0,0,2,0" Background="Transparent" Width="25" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickButtonSetting">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Image x:Name="ImageSetting" Width="25" Height="25" Source="/eDIAN;component/Resources/images/image_setting_on.png" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ImageSetting" Property="Source" Value="/eDIAN;component/Resources/images/image_setting_over.png" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- 로그인 버튼 -->
                                    <Button x:Name="ButtonAuthentification" Background="Transparent" Width="48" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickButtonLogin">
                                        <Image x:Name="ImageAuthentification" Width="48" Height="25" MouseEnter="toggleImageAuthentification" MouseLeave="toggleImageAuthentification"/>
                                    </Button>
                                </StackPanel>

                            </Grid>

                        </Grid>

                        <!-- [로그인 사용자 정보, 파일 열기 버튼 영역] -->

                        <Grid Grid.Row="1" Height="28">

                            <Grid Background="Transparent" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="75" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Height="28" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <!-- 라이센스 이미지 : width 가변 -->
                                    <Image x:Name="IconLicenseType" Margin="0,0,4,0" Height="18"/>
                                    <!-- 로그인 사용자 명 -->
                                    <TextBlock x:Name="UserName" FontSize="12" Foreground="#FFF5F5F5" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid Grid.Column="2" Width="75" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <!-- 파일 열기 버튼 -->
                                    <Button x:Name="ButtonOpenFile" Background="Transparent" Width="73" Height="18" Margin="0,2,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickButtonOpenFile">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Image x:Name="ImageOpenFile" Width="73" Height="18" Source="/eDIAN;component/Resources/images/image_open_on.png" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ImageOpenFile" Property="Source" Value="/eDIAN;component/Resources/images/image_open_over.png" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                            </Grid>

                        </Grid>

                    </Grid>

                </Border>

                <Grid Grid.Row="1" Background="Transparent" Height="10"></Grid>

                <Border Grid.Row="2" Background="#FF424C58" CornerRadius="6,6,0,0" Padding="6,6,6,6">

                    <!-- [열린 파일 목록] -->

                    <ListBox x:Name="DocumentList" Background="Transparent" Foreground="#FFF5F5F5" BorderThickness="0" BorderBrush="Transparent" Padding="0" d:ItemsSource="{d:SampleData}"
                             AllowDrop="False"
                             PreviewMouseLeftButtonDown="previewMouseLeftButtonDown"
                             PreviewMouseMove="previewMouseMove"
                             Drop="dropListItem"
                             DragOver="dragOverListItem"
                             MouseLeftButtonUp="onChangedDocument">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="62" />
                                <Setter Property="Padding" Value="4" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Background" Value="#FF2F3A47" />
                                <Setter Property="Foreground" Value="#FFA7B2BF" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" SnapsToDevicePixels="True">
                                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF1F262E"/>
                                                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                            </Style>

                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            
                            <DataTemplate>

                                <!-- 리스트 항목 -->

                                <Border Background="Transparent">

                                    <Grid>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="25" />
                                            <RowDefinition Height="2" />
                                            <RowDefinition Height="27" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Height="25">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="25" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">
                                                <!-- 파일 타입 아이콘 -->
                                                <Image x:Name="IconFileType" Source="{Binding IconFileType}" Width="19" Height="19" />
                                            </Grid>

                                            <Grid Grid.Column="1" HorizontalAlignment="Left">

                                                <!-- !!! 런타임시 주석 해제. 디자인 보기시에는 주석 적용 -->
                                                
                                                <Grid.Width>
                                                    <Binding ElementName="RootControl" Path="ActualWidth">
                                                        <Binding.Converter><local:WidthRatioConverter /></Binding.Converter>
                                                        <Binding.ConverterParameter>0.7</Binding.ConverterParameter>
                                                    </Binding>
                                                </Grid.Width>

                                                <!--  런타임시 주석 해제. 디자인 보기시에는 주석 적용 !!! -->

                                                <!-- 파일명 -->
                                                <TextBlock Text="{Binding displayName}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding displayName}" />
                                            </Grid>

                                            <Grid Grid.Column="2">
                                                <!-- 닫기 버튼 -->
                                                <Button x:Name="ButtonClose" Background="Transparent" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickButtonClose">
                                                    <Image x:Name="ImageClose" Source="/eDIAN;component/Resources/images/image_close_on.png" Width="18" Height="18"/>
                                                </Button>
                                            </Grid>

                                        </Grid>
                                        <Grid Grid.Row="1" Height="2"/>
                                        <Grid Grid.Row="2" Height="27">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="34" Height="27">
                                                <!-- 소유자 아이콘 -->
                                                <Image x:Name="IconOwner" Source="{Binding IconOwner}" Width="27" Height="27" ToolTip="{Binding ToolTipOwner}" />
                                            </Grid>

                                            <Grid Grid.Column="1" Width="34" Height="27">
                                                <!-- 보기 권한 아이콘 -->
                                                <Image x:Name="IconView" Source="{Binding IconView}" Width="27" Height="27" ToolTip="{Binding ToolTipView}" />
                                            </Grid>

                                            <Grid Grid.Column="2" Width="34" Height="27">
                                                <!-- 복사 권한 아이콘 -->
                                                <Image x:Name="IconCopy" Source="{Binding IconCopy}" Width="27" Height="27" ToolTip="{Binding ToolTipCopy}" />
                                            </Grid>

                                            <Grid Grid.Column="3" Width="34" Height="27">
                                                <!-- 출력 권한 아이콘 -->
                                                <Image x:Name="IconPrint" Source="{Binding IconPrint}" Width="27" Height="27" ToolTip="{Binding ToolTipPrint}" />
                                            </Grid>

                                            <Grid Grid.Column="4" Width="34" Height="27">
                                                <!-- 저장 권한 아이콘 -->
                                                <Image x:Name="IconSave" Source="{Binding IconSave}" Width="27" Height="27" ToolTip="{Binding ToolTipSave}"/>
                                            </Grid>

                                            <Grid Grid.Column="5" Height="27" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <!-- 적용 버튼 -->
                                                <Button x:Name="ButtonSensibility" Background="Transparent" Width="60" Height="19" Visibility="{Binding buttonSensibilityVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" BorderThickness="0" Cursor="Hand" Click="onClickButtonApply">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Image x:Name="ImageSensibility" Source="/eDIAN;component/Resources/images/image_sensibility_on.png" Width="60" Height="19" />
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ImageSensibility" Property="Source" Value="/eDIAN;component/Resources/images/image_sensibility_over.png" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                        </Grid>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                    </ListBox>

                </Border>

            </Grid>

        </Grid>
        <Grid Grid.Column="2" Width="6"><!--우측 여백--></Grid>
    </Grid>
    
</UserControl>